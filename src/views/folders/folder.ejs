<div class="root-page">
  <% if (locals.showUploadDialog) { %> <%- include ("../files/newFile.ejs") %>
  <% } %> <% if (locals.showDeleteDialog) { %> <%- include
  ("../files/deleteFileDialog.ejs") %> <% } %> %>
  <div class="root-header">
    <h1><%= folder.name %> Folder</h1>
    <a href="/folders/<%= folder.id %>/files/new"
      ><button class="add-entry-button">Upload File</button></a
    >
  </div>
  <div class="files-container">
    <table class="files-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Size</th>
          <th>Upload Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% files.forEach(file => { %>
        <tr>
          <td>
            <div class="name-wrapper">
              <% if (file.mimetype === 'application/pdf') { %>
              <i class="fa-solid fa-file-pdf"></i>
              <% } else if (file.mimetype === "image/jpeg" || file.mimetype ===
              "image/png") {%>
              <i class="fa-solid fa-image"></i>
              <% } else {%>
              <i class="fa-solid fa-file"></i>
              <% } %>

              <p><%= file.filename %></p>
            </div>
          </td>
          <td><%= file.size %></td>
          <td><%= file.createdAt %></td>
          <td class="btn-group">
            <a href="/files/<%= file.id %>/download">
              <i class="fa-solid fa-download fa-lg"></i>
            </a>
            <a href="/folders/<%= folder.id %>/files/<%= file.id %>/delete">
              <i class="fa-solid fa-trash fa-lg"></i>
            </a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
